generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlserver"
}

// ──────────────────────────────────────────────
// PLANS — Abonelik planları
// ──────────────────────────────────────────────
model Plan {
  id               String   @id @default(uuid())
  name             String   @db.NVarChar(100)
  price_monthly    Decimal  @db.Decimal(10, 2)
  max_staff        Int
  max_services     Int
  whatsapp_enabled Boolean  @default(false)
  custom_domain    Boolean  @default(false)
  waitlist_enabled Boolean  @default(true)
  analytics        Boolean  @default(false)
  priority_support Boolean  @default(false)
  created_at       DateTime @default(now())

  tenants              Tenant[]
  tenant_subscriptions TenantSubscription[]
  coupons              Coupon[]

  @@map("Plans")
}

// ──────────────────────────────────────────────
// TENANTS — Kiracı / İşletme
// ──────────────────────────────────────────────
model Tenant {
  id            String   @id @default(uuid())
  domain_slug   String   @unique @db.NVarChar(100)
  custom_domain String?  @db.NVarChar(255)
  company_name  String   @db.NVarChar(255)
  sector        String   @db.NVarChar(100)
  theme_config  String   @db.NVarChar(Max) // JSON string
  logo_url      String?  @db.NVarChar(500)
  owner_email   String   @db.NVarChar(255)
  owner_name    String   @db.NVarChar(255)
  password_hash String   @db.NVarChar(255)
  plan_id       String
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  plan              Plan               @relation(fields: [plan_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  staff             Staff[]
  services          Service[]
  staff_services    StaffService[]
  appointments      Appointment[]
  waitlist          WaitlistEntry[]
  subscriptions      TenantSubscription[]
  billing_addresses  BillingAddress[]
  coupon_usages      CouponUsage[]
  notification_logs  NotificationLog[]
  error_logs        ErrorLog[]
  support_tickets   SupportTicket[]
  closed_days       ClosedDay[]
  webhook_endpoints WebhookEndpoint[]

  @@map("Tenants")
}

// ──────────────────────────────────────────────
// STAFF — Personel
// ──────────────────────────────────────────────
model Staff {
  id         String   @id @default(uuid())
  tenant_id  String
  full_name  String   @db.NVarChar(255)
  title      String?  @db.NVarChar(100)
  photo_url  String?  @db.NVarChar(500)
  work_hours String   @db.NVarChar(Max) // JSON: {"mon":[{"start":"09:00","end":"18:00"}],...}
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  tenant         Tenant         @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  staff_services StaffService[]
  appointments   Appointment[]
  closed_days    ClosedDay[]

  @@map("Staff")
}

// ──────────────────────────────────────────────
// SERVICES — Hizmetler
// ──────────────────────────────────────────────
model Service {
  id           String   @id @default(uuid())
  tenant_id    String
  name         String   @db.NVarChar(255)
  description  String?  @db.NVarChar(Max)
  duration_min Int
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())

  tenant         Tenant         @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  staff_services StaffService[]
  appointments   Appointment[]

  @@map("Services")
}

// ──────────────────────────────────────────────
// STAFF_SERVICES — Hangi personel hangi hizmeti verir
// ──────────────────────────────────────────────
model StaffService {
  id         String @id @default(uuid())
  tenant_id  String
  staff_id   String
  service_id String

  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  staff   Staff   @relation(fields: [staff_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  service Service @relation(fields: [service_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@unique([staff_id, service_id])
  @@map("StaffServices")
}

// ──────────────────────────────────────────────
// APPOINTMENTS — Randevular
// status: PENDING | CONFIRMED | CANCELLED | COMPLETED | NO_SHOW
// ──────────────────────────────────────────────
model Appointment {
  id             String   @id @default(uuid())
  tenant_id      String
  staff_id       String
  service_id     String
  customer_name  String   @db.NVarChar(255)
  customer_phone String   @db.NVarChar(20)
  customer_email String   @db.NVarChar(255)
  start_time     DateTime
  end_time       DateTime
  status         String   @default("PENDING") @db.NVarChar(20)
  notes          String?  @db.NVarChar(Max)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  tenant   Tenant          @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  staff    Staff           @relation(fields: [staff_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  service  Service         @relation(fields: [service_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  waitlist WaitlistEntry[]

  @@map("Appointments")
}

// ──────────────────────────────────────────────
// WAITLIST — Bekleme listesi
// status: WAITING | NOTIFIED | CONFIRMED | EXPIRED | CANCELLED
// ──────────────────────────────────────────────
model WaitlistEntry {
  id             String    @id @default(uuid())
  tenant_id      String
  appointment_id String
  customer_name  String    @db.NVarChar(255)
  customer_phone String    @db.NVarChar(20)
  customer_email String    @db.NVarChar(255)
  queue_order    Int
  notified_at    DateTime?
  expires_at     DateTime?
  status         String    @default("WAITING") @db.NVarChar(20)
  created_at     DateTime  @default(now())

  tenant      Tenant      @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  appointment Appointment @relation(fields: [appointment_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("Waitlist")
}

// ──────────────────────────────────────────────
// BILLING_ADDRESSES — Fatura adresleri
// type: BIREYSEL | KURUMSAL
// ──────────────────────────────────────────────
model BillingAddress {
  id           String   @id @default(uuid())
  tenant_id    String
  type         String   @db.NVarChar(20) // BIREYSEL | KURUMSAL
  label        String?  @db.NVarChar(100) // "Ev Adresi", "Ofis" vb.
  // Bireysel alanlar
  full_name    String?  @db.NVarChar(255)
  tc_kimlik    String?  @db.NVarChar(11)
  // Kurumsal alanlar
  company_name String?  @db.NVarChar(255)
  tax_office   String?  @db.NVarChar(255) // Vergi Dairesi
  tax_number   String?  @db.NVarChar(20)  // Vergi No
  // Ortak alanlar
  address      String   @db.NVarChar(500)
  city         String   @db.NVarChar(100) // İl
  district     String   @db.NVarChar(100) // İlçe
  phone        String   @db.NVarChar(20)
  is_default   Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant        Tenant               @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  subscriptions TenantSubscription[]
  invoices      Invoice[]

  @@map("BillingAddresses")
}

// ──────────────────────────────────────────────
// PENDING_PAYMENTS — Ödeme bekleyen işlemler
// PayTR merchant_oid max 64 karakter olduğu için
// ödeme metadata'sı burada tutulur
// ──────────────────────────────────────────────
model PendingPayment {
  id                 String   @id @default(uuid())
  tenant_id          String
  plan_id            String
  billing_period     String   @db.NVarChar(10) // MONTHLY | YEARLY
  billing_address_id String
  merchant_oid       String   @unique @db.NVarChar(64)
  net_amount         Decimal  @db.Decimal(10, 2)
  total_amount       Decimal  @db.Decimal(10, 2)
  coupon_id          String?  // kullanılan kupon ID'si
  status             String   @default("PENDING") @db.NVarChar(20) // PENDING | COMPLETED | FAILED
  created_at         DateTime @default(now())

  @@map("PendingPayments")
}

// ──────────────────────────────────────────────
// TENANT_SUBSCRIPTIONS — Abonelik ödemeleri
// status: ACTIVE | EXPIRED | CANCELLED | PENDING | REFUNDED
// ──────────────────────────────────────────────
model TenantSubscription {
  id                 String    @id @default(uuid())
  tenant_id          String
  plan_id            String
  paytr_ref          String?   @db.NVarChar(255)
  billing_period     String    @default("MONTHLY") @db.NVarChar(10) // MONTHLY | YEARLY
  net_amount         Decimal?  @db.Decimal(10, 2)
  total_amount       Decimal?  @db.Decimal(10, 2)
  billing_address_id String?
  coupon_id          String?
  starts_at          DateTime
  ends_at            DateTime
  status             String    @default("ACTIVE") @db.NVarChar(20)
  created_at         DateTime  @default(now())

  tenant          Tenant          @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  plan            Plan            @relation(fields: [plan_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  billing_address BillingAddress? @relation(fields: [billing_address_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  coupon          Coupon?         @relation(fields: [coupon_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  invoices        Invoice[]
  coupon_usages   CouponUsage[]

  @@map("TenantSubscriptions")
}

// ──────────────────────────────────────────────
// INVOICES — Faturalar
// status: FATURA_BEKLIYOR | FATURA_YUKLENDI
// ──────────────────────────────────────────────
model Invoice {
  id                 String    @id @default(uuid())
  subscription_id    String
  billing_address_id String
  invoice_number     String    @unique @db.NVarChar(20) // INV-2026-0001
  net_amount         Decimal   @db.Decimal(10, 2)
  kdv_rate           Int       @default(20)
  kdv_amount         Decimal   @db.Decimal(10, 2)
  total_amount       Decimal   @db.Decimal(10, 2)
  status             String    @default("FATURA_BEKLIYOR") @db.NVarChar(30)
  pdf_url            String?   @db.NVarChar(500)
  pdf_public_id      String?   @db.NVarChar(255)
  emailed_at         DateTime?
  created_at         DateTime  @default(now())

  subscription    TenantSubscription @relation(fields: [subscription_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  billing_address BillingAddress     @relation(fields: [billing_address_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("Invoices")
}

// ──────────────────────────────────────────────
// NOTIFICATION_LOGS — Bildirim gönderim logu
// channel: EMAIL | WHATSAPP
// status: SENT | FAILED | PENDING
// ──────────────────────────────────────────────
model NotificationLog {
  id         String   @id @default(uuid())
  tenant_id  String
  channel    String   @db.NVarChar(20)
  recipient  String   @db.NVarChar(255)
  event_type String   @db.NVarChar(100)
  status     String   @default("SENT") @db.NVarChar(20)
  error_msg  String?  @db.NVarChar(Max)
  sent_at    DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("NotificationLogs")
}

// ──────────────────────────────────────────────
// ERROR_LOGS — Sistem hata kayıtları
// ──────────────────────────────────────────────
model ErrorLog {
  id           String   @id @default(uuid())
  tenant_id    String?
  user_email   String?  @db.NVarChar(255)
  user_role    String?  @db.NVarChar(50)
  endpoint     String   @db.NVarChar(500)
  method       String   @db.NVarChar(10)
  status_code  Int      @default(500)
  error_msg    String   @db.NVarChar(Max)
  stack_trace  String?  @db.NVarChar(Max)
  ip_address   String?  @db.NVarChar(100)
  created_at   DateTime @default(now())

  tenant Tenant? @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("ErrorLogs")
}

// ──────────────────────────────────────────────
// ADMIN_USERS — Platform yöneticileri
// role: SUPER_ADMIN | SUPPORT | BILLING | VIEWER
// ──────────────────────────────────────────────
model AdminUser {
  id            String    @id @default(uuid())
  email         String    @unique @db.NVarChar(255)
  password_hash String    @db.NVarChar(255)
  full_name     String    @db.NVarChar(255)
  role          String    @default("SUPPORT") @db.NVarChar(50)
  // SUPER_ADMIN: tam yetki | SUPPORT: destek + okuma | BILLING: ödeme/iade | VIEWER: salt okunur
  is_active     Boolean   @default(true)
  last_login_at DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  support_messages SupportMessage[]

  @@map("AdminUsers")
}

// ──────────────────────────────────────────────
// SUPPORT_TICKETS — Destek talepleri
// status: OPEN | IN_PROGRESS | RESOLVED | CLOSED
// priority: LOW | NORMAL | HIGH | URGENT
// ──────────────────────────────────────────────
model SupportTicket {
  id         String   @id @default(uuid())
  tenant_id  String
  subject    String   @db.NVarChar(500)
  status     String   @default("OPEN") @db.NVarChar(20)
  priority   String   @default("NORMAL") @db.NVarChar(20)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant   Tenant           @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  messages SupportMessage[]

  @@map("SupportTickets")
}

// ──────────────────────────────────────────────
// CLOSED_DAYS — Özel kapalı günler / tatiller
// staff_id null ise tüm işletme kapalı
// ──────────────────────────────────────────────
model ClosedDay {
  id         String   @id @default(uuid())
  tenant_id  String
  staff_id   String?
  date       DateTime // sadece tarih kısmı kullanılır (saat 00:00)
  reason     String?  @db.NVarChar(255)
  created_at DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  staff  Staff?  @relation(fields: [staff_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("ClosedDays")
}

// ──────────────────────────────────────────────
// WEBHOOK_ENDPOINTS — Tenant webhook hedefleri
// ──────────────────────────────────────────────
model WebhookEndpoint {
  id         String   @id @default(uuid())
  tenant_id  String
  url        String   @db.NVarChar(500)
  secret     String   @db.NVarChar(255) // HMAC imzalama anahtarı
  events     String   @db.NVarChar(Max) // JSON array: ["appointment.created","*"]
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  tenant Tenant       @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  logs   WebhookLog[]

  @@map("WebhookEndpoints")
}

// ──────────────────────────────────────────────
// WEBHOOK_LOGS — Webhook teslimat geçmişi
// ──────────────────────────────────────────────
model WebhookLog {
  id          String   @id @default(uuid())
  endpoint_id String
  event       String   @db.NVarChar(100)
  payload     String   @db.NVarChar(Max)
  status_code Int?
  success     Boolean
  error_msg   String?  @db.NVarChar(Max)
  created_at  DateTime @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpoint_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("WebhookLogs")
}

// ──────────────────────────────────────────────
// LEGAL_DOCUMENTS — Yasal sözleşme metinleri
// type: PRIVACY_POLICY | TERMS_OF_USE | COOKIE_POLICY | KVKK | DISTANCE_SALES | CANCELLATION_POLICY
// ──────────────────────────────────────────────
model LegalDocument {
  id         String   @id @default(uuid())
  type       String   @db.NVarChar(50)
  title      String   @db.NVarChar(255)
  content    String   @db.NVarChar(Max) // HTML içerik
  version    String   @db.NVarChar(20)  // "1.0", "1.1" vb.
  is_active  Boolean  @default(true)    // sadece bir versiyon aktif olmalı
  created_at DateTime @default(now())

  consents UserConsent[]

  @@map("LegalDocuments")
}

// ──────────────────────────────────────────────
// USER_CONSENTS — Kullanıcı sözleşme onay kayıtları
// user_type: TENANT | STAFF
// ──────────────────────────────────────────────
model UserConsent {
  id          String   @id @default(uuid())
  document_id String
  user_type   String   @db.NVarChar(20)  // TENANT | STAFF
  tenant_id   String?  // user_type TENANT ise dolu
  staff_id    String?  // user_type STAFF ise dolu
  user_email  String   @db.NVarChar(255)
  ip_address  String   @db.NVarChar(100)
  user_agent  String?  @db.NVarChar(Max)
  accepted_at DateTime @default(now())

  document LegalDocument @relation(fields: [document_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("UserConsents")
}

// ──────────────────────────────────────────────
// SUPPORT_MESSAGES — Destek talebi mesajları
// sender: TENANT | ADMIN
// ──────────────────────────────────────────────
model SupportMessage {
  id         String   @id @default(uuid())
  ticket_id  String
  sender     String   @db.NVarChar(20) // TENANT | ADMIN
  admin_id   String?  // sender == ADMIN ise dolu
  content    String   @db.NVarChar(Max)
  created_at DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticket_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  admin  AdminUser?    @relation(fields: [admin_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("SupportMessages")
}

// ──────────────────────────────────────────────
// COUPONS — İndirim kuponları
// ──────────────────────────────────────────────
model Coupon {
  id               String   @id @default(uuid())
  code             String   @unique @db.NVarChar(50) // büyük harf: HOSGELDIN50
  discount_percent Int      // 1-100
  plan_id          String?  // null = tüm planlarda geçerli
  valid_from       DateTime
  valid_until      DateTime
  max_uses         Int
  used_count       Int      @default(0)
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())

  plan          Plan?                @relation(fields: [plan_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  usages        CouponUsage[]
  subscriptions TenantSubscription[]

  @@map("Coupons")
}

// ──────────────────────────────────────────────
// COUPON_USAGES — Kupon kullanım logları
// ──────────────────────────────────────────────
model CouponUsage {
  id              String   @id @default(uuid())
  coupon_id       String
  tenant_id       String
  subscription_id String?
  discount_amount Decimal  @db.Decimal(10, 2) // uygulanan indirim tutarı (TL)
  original_amount Decimal  @db.Decimal(10, 2) // orijinal toplam tutar
  final_amount    Decimal  @db.Decimal(10, 2) // indirimli tutar
  used_at         DateTime @default(now())

  coupon       Coupon              @relation(fields: [coupon_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  tenant       Tenant              @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  subscription TenantSubscription? @relation(fields: [subscription_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("CouponUsages")
}

// ──────────────────────────────────────────────
// EMAIL_CONFIG — SMTP e-posta ayarları (singleton)
// Admin panelden değiştirilebilir
// ──────────────────────────────────────────────
model EmailConfig {
  id         String   @id @default(uuid())
  smtp_host  String   @db.NVarChar(255)
  smtp_port  Int
  smtp_secure Boolean @default(true)
  smtp_user  String   @db.NVarChar(255)
  smtp_pass  String   @db.NVarChar(255)
  from_email String   @db.NVarChar(255)
  from_name  String   @db.NVarChar(100)
  is_active  Boolean  @default(true)
  updated_at DateTime @updatedAt

  @@map("EmailConfig")
}

// ──────────────────────────────────────────────
// PASSWORD_RESET_TOKENS — Şifre sıfırlama tokenları
// ──────────────────────────────────────────────
model PasswordResetToken {
  id         String   @id @default(uuid())
  email      String   @db.NVarChar(255)
  token      String   @unique @db.NVarChar(255)
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())

  @@map("PasswordResetTokens")
}
